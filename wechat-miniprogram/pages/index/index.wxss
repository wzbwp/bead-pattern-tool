.page {
  padding: 24rpx;
}

.topbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0 22rpx;
}

.eyebrow,
.title,
.meta-title,
.meta-sub,
.row-title,
.color-code {
  display: block;
}

.eyebrow {
  color: #08746e;
  font-size: 22rpx;
  font-weight: 800;
  text-transform: uppercase;
}

.title {
  margin-top: 6rpx;
  color: #1c2529;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.1;
}

.status {
  min-width: 128rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid #dbe3e6;
  border-radius: 8rpx;
  background: #ffffff;
  color: #68777f;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.status.ready {
  border-color: rgba(15, 143, 134, 0.35);
  background: #d9f2ef;
  color: #08746e;
}

.panel {
  margin-bottom: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #dbe3e6;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(37, 51, 57, 0.08);
}

.primary-button,
.plain-button,
.preset {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 8rpx;
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1;
}

.primary-button {
  background: #0f8f86;
  color: #ffffff;
}

.primary-button[disabled],
.plain-button[disabled] {
  opacity: 0.45;
}

.plain-button,
.preset {
  border: 1rpx solid #becbd0;
  background: #ffffff;
  color: #1c2529;
}

.image-meta {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.source-preview {
  width: 104rpx;
  height: 104rpx;
  border: 1rpx solid #dbe3e6;
  border-radius: 8rpx;
  background: #f0f4f5;
}

.meta-title {
  max-width: 500rpx;
  color: #1c2529;
  font-size: 28rpx;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-sub {
  margin-top: 6rpx;
  color: #68777f;
  font-size: 23rpx;
  font-weight: 700;
}

.row-title {
  margin: 10rpx 0 14rpx;
  color: #1c2529;
  font-size: 25rpx;
  font-weight: 900;
}

.field-grid,
.switch-grid {
  display: grid;
  gap: 12rpx;
}

.preset-row {
  display: flex;
  gap: 12rpx;
}

.preset-row .preset {
  flex: 1 1 0;
  min-width: 0;
  padding: 0 6rpx;
}

.preset.active {
  border-color: #0f8f86;
  background: #d9f2ef;
  color: #08746e;
}

.field-grid {
  grid-template-columns: repeat(2, 1fr);
  margin: 16rpx 0;
}

.field {
  display: block;
  padding: 14rpx;
  border: 1rpx solid #dbe3e6;
  border-radius: 8rpx;
  background: #f9fbfb;
}

.field text {
  display: block;
  color: #68777f;
  font-size: 22rpx;
  font-weight: 800;
}

.field input {
  margin-top: 8rpx;
  height: 48rpx;
  color: #1c2529;
  font-size: 30rpx;
  font-weight: 850;
}

.picker-value {
  min-height: 70rpx;
  padding: 20rpx;
  border: 1rpx solid #dbe3e6;
  border-radius: 8rpx;
  background: #f9fbfb;
  color: #1c2529;
  font-size: 27rpx;
  font-weight: 800;
}

.switch-grid {
  grid-template-columns: repeat(2, 1fr);
  margin: 20rpx 0;
}

.switch-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #1c2529;
  font-size: 25rpx;
  font-weight: 800;
}

.result-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.result-actions {
  display: flex;
  gap: 10rpx;
}

.result-actions .plain-button {
  width: 132rpx;
  min-height: 64rpx;
  padding: 0;
}

.edit-toolbar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 14rpx;
  border: 1rpx solid #dbe3e6;
  border-radius: 8rpx;
  background: #f9fbfb;
}

.tool-button {
  min-height: 58rpx;
  padding: 0 18rpx;
  border: 1rpx solid #becbd0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1c2529;
  font-size: 24rpx;
  font-weight: 850;
}

.tool-button.active {
  border-color: #0f8f86;
  background: #d9f2ef;
  color: #08746e;
}

.selected-color {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #1c2529;
  font-size: 23rpx;
  font-weight: 800;
}

.selected-swatch {
  width: 34rpx;
  height: 34rpx;
  border: 1rpx solid rgba(28, 37, 41, 0.2);
  border-radius: 6rpx;
}

.edit-tip {
  flex-basis: 100%;
  color: #68777f;
  font-size: 22rpx;
  font-weight: 700;
}

.canvas-scroll {
  position: relative;
  width: 100%;
  height: 650rpx;
  margin-top: 16rpx;
  border: 1rpx solid #dbe3e6;
  border-radius: 8rpx;
  background: #f0f4f5;
}

.pattern-canvas {
  display: block;
  background: #ffffff;
}

.empty-state {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #68777f;
  font-size: 26rpx;
  font-weight: 800;
}

.palette-list {
  display: grid;
  gap: 10rpx;
}

.color-item {
  display: grid;
  grid-template-columns: 48rpx 1fr auto;
  align-items: center;
  gap: 14rpx;
  min-height: 70rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #eef2f3;
}

.color-item:last-child {
  border-bottom: 0;
}

.color-item.selected {
  margin: 0 -10rpx;
  padding: 10rpx;
  border: 1rpx solid #0f8f86;
  border-radius: 8rpx;
  background: #d9f2ef;
}

.swatch {
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid rgba(28, 37, 41, 0.16);
  border-radius: 6rpx;
}

.color-code,
.count {
  color: #1c2529;
  font-size: 27rpx;
  font-weight: 900;
}

.count {
  font-variant-numeric: tabular-nums;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}
